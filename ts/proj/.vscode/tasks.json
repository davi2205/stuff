{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "tsc: build",
      "type": "shell",
      "command": "tsc",
      "args": ["-p", "tsconfig.json"],
      "group": "build",
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "tsc: watch",
      "type": "shell",
      "command": "tsc",
      "args": ["-p", "tsconfig.json", "--watch", "--preserveWatchOutput"],
      "isBackground": true,
      "group": "build",
      "problemMatcher": ["$tsc-watch"]
    }
  ]
}